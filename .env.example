# Session encryption. At least 32 characters (e.g. openssl rand -base64 32)
SESSION_SECRET='dev-session-secret-change-in-production-min-32-chars'

# AES-128-GCM key. Must be base64-encoded 16 bytes (e.g. openssl rand -base64 16)
ENCRYPTION_KEY='MTIzNDU2Nzg5MDEyMzQ1Ng=='

# PostgreSQL connection string
DATABASE_URL='postgresql://postgres:postgres@localhost:5432/harmonogram_us'
