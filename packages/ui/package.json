{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./components/*": {
      "import": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./composed/*": {
      "import": "./src/composed/*.tsx",
      "default": "./src/composed/*.tsx"
    },
    "./utils": "./src/utils.ts",
    "./tailwind": "./tailwind.css"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "add:ui": "pnpm dlx shadcn@latest add -c . -p src/components"
  },
  "dependencies": {
    "@marsidev/react-turnstile": "^1.5.0",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@repo/api": "workspace:*",
    "@repo/env": "workspace:*",
    "@repo/i18n": "workspace:*",
    "@tanstack/react-form": "^1.29.1",
    "@tanstack/react-query": "^5.100.1",
    "@tanstack/react-router": "^1.168.23",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/react": "^19.2.14",
    "react": "^19.2.5",
    "tailwindcss": "^4.2.4",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
