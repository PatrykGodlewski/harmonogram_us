{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./components/*": {
      "import": "./src/components/*.tsx",
      "default": "./src/components/*.tsx"
    },
    "./composed/*": {
      "import": "./src/composed/*.tsx",
      "default": "./src/composed/*.tsx"
    },
    "./utils": "./src/utils.ts",
    "./tailwind": "./tailwind.css"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "biome check .",
    "add:ui": "npx shadcn@latest add -c . -p src/components"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@repo/config": "workspace:*",
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  }
}
